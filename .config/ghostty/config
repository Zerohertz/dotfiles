font-family = JetBrainsMono Nerd Font Mono
font-family = Sarasa Term K
font-size = 16
# font-codepoint-map = U+E000-U+F8FF=MesloLGS NF

background = #000000
selection-background = #800a0a
palette = 0=#000000
palette = 1=#cc0403
palette = 2=#19cb00
palette = 3=#cecb00
palette = 4=#800a0a
palette = 5=#cb1ed1
palette = 6=#0dcdcd
palette = 7=#dddddd
palette = 8=#767676
palette = 9=#f2201f
palette = 10=#23fd00
palette = 11=#fffd00
palette = 12=#1a8fff
palette = 13=#fd28ff
palette = 14=#14ffff
palette = 15=#ffffff
cursor-color = #ffffff
working-directory = home

# keybind = super+a=select_all
# Additional kitty-style keybinds
keybind = ctrl+shift+left=previous_tab
keybind = ctrl+shift+right=next_tab
keybind = ctrl+shift+comma=move_tab:-1
keybind = ctrl+shift+period=move_tab:1
keybind = super+enter=new_split:down
keybind = super+a=toggle_split_zoom
keybind = super+s=goto_split:next

window-inherit-working-directory = false
confirm-close-surface = false
